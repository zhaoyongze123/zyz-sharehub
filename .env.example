# 应用环境
APP_ENV=local
SPRING_PROFILES_ACTIVE=local

# GitHub OAuth
GITHUB_OAUTH_ENABLED=true
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# PostgreSQL / Redis
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=55432
POSTGRES_DB=sharehub_dev
POSTGRES_USER=sharehub_dev
POSTGRES_PASSWORD=replace_postgres_password
REDIS_HOST=127.0.0.1
REDIS_PORT=56379
REDIS_PASSWORD=replace_redis_password

# 后台安全
SHAREHUB_ADMIN_DEV_TOKEN_ENABLED=false
SHAREHUB_ADMIN_REQUIRE_POSTGRES=true

# DigitalOcean Spaces
DO_SPACES_ENDPOINT=https://<region>.digitaloceanspaces.com
DO_SPACES_REGION=<region>
DO_SPACES_BUCKET=sharehub
DO_SPACES_ACCESS_KEY=your_access_key
DO_SPACES_SECRET_KEY=your_secret_key
