# 基础
TZ=Asia/Shanghai
APP_ENV=production
SPRING_PROFILES_ACTIVE=production,oauth

# PostgreSQL
POSTGRES_DB=sharehub
POSTGRES_USER=sharehub
POSTGRES_PASSWORD=replace_postgres_password

# Redis
REDIS_PASSWORD=replace_redis_password

# 后台安全
SHAREHUB_ADMIN_DEV_TOKEN_ENABLED=false

# GitHub OAuth
GITHUB_OAUTH_ENABLED=true
# GitHub OAuth App Homepage URL: https://your-domain.com
# GitHub OAuth App Callback URL: https://your-domain.com/login/oauth2/code/github
GITHUB_CLIENT_ID=replace_github_client_id
GITHUB_CLIENT_SECRET=replace_github_client_secret

# DigitalOcean Spaces（当前生产启动不是必填。只有文件主链路切到对象存储后才需要填真实值）
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_REGION=sgp1
DO_SPACES_BUCKET=replace_bucket
DO_SPACES_ACCESS_KEY=replace_spaces_key
DO_SPACES_SECRET_KEY=replace_spaces_secret
