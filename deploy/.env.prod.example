# 基础
TZ=Asia/Shanghai
SPRING_PROFILES_ACTIVE=oauth

# MySQL
MYSQL_ROOT_PASSWORD=replace_root_password
MYSQL_DATABASE=sharehub
MYSQL_USER=sharehub
MYSQL_PASSWORD=replace_mysql_password

# Redis
REDIS_PASSWORD=replace_redis_password

# GitHub OAuth
GITHUB_OAUTH_ENABLED=true
GITHUB_CLIENT_ID=replace_github_client_id
GITHUB_CLIENT_SECRET=replace_github_client_secret

# DigitalOcean Spaces
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_REGION=sgp1
DO_SPACES_BUCKET=replace_bucket
DO_SPACES_ACCESS_KEY=replace_spaces_key
DO_SPACES_SECRET_KEY=replace_spaces_secret
